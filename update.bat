@echo offset "GIT_PATH=C:\Program Files\Git\cmd\git.exe"where git >nul 2>nulif %errorlevel% neq 0 (    if exist "%GIT_PATH%" (        set "GIT_CMD=\"%GIT_PATH%\""    ) else (        echo ERROR: Git is not found. Please install Git to use this updater.        echo You can download it from: https://git-scm.com/        pause        exit /b    )) else (    set "GIT_CMD=git")echo Updating the RejoinTool...echo.%GIT_CMD% pull --rebase --autostash origin masterif %errorlevel% neq 0 (  echo.  echo ###########################################################  echo #   ERROR: The update failed.                             #  echo #   There might be conflicts or network issues.           #  echo ###########################################################) else (  echo.  echo Update complete!)echo.pause